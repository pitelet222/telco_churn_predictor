# ── Required ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here

# ── Optional (defaults shown) ───────────────────────────────────────────
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.7
# OPENAI_MAX_TOKENS=600

# ── Training ─────────────────────────────────────────────────────────────
# TEST_SIZE=0.3
# RANDOM_STATE=42
# CV_FOLDS=5

# ── Prediction ───────────────────────────────────────────────────────────
# SHAP_TOP_N=5

# ── Streamlit UI ─────────────────────────────────────────────────────────
# APP_TITLE=ChurnGuard AI
# APP_ICON=🛡️

# ── Environment & Security ───────────────────────────────────────────────
# ENVIRONMENT=development          # development | staging | production
# CHURN_THRESHOLD=0.5              # classification threshold (lower → higher recall)
# API_KEY=                         # if set, all API requests require X-API-Key header
# API_CORS_ORIGINS=["*"]           # restrict in production: ["https://yourdomain.com"]

# ── Logging ──────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_DIR=logs
